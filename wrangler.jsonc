{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "glyphweave",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-05",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "wasm_modules": {
    "RESVG_WASM": "dist/resvg-wasm.wasm"
  },
  "assets": {
    "directory": "dist"
  }
}
